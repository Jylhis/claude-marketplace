{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Claude Marketplace Manifest",
  "type": "object",
  "required": ["name", "version", "description", "author", "category"],
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$",
      "description": "Kebab-case identifier"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semantic version"
    },
    "description": {
      "type": "string",
      "maxLength": 200
    },
    "author": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string" },
        "github": { "type": "string" }
      }
    },
    "license": {
      "type": "string",
      "default": "MIT"
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "category": {
      "type": "string",
      "enum": ["skills", "mcp-servers", "hooks", "slash-commands"]
    },
    "install": {
      "type": "object",
      "properties": {
        "instructions": { "type": "string" }
      }
    }
  }
}
